{
  "name": "realtime-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:realtime-app": "node dist/realtime-app/server/server.mjs",
    "build:capacitor": "ng build --configuration capacitor",
    "cap:sync": "npm run build:capacitor && cap sync",
    "cap:android": "npm run build:capacitor && cap sync android && cap open android",
    "cap:run:android": "npm run build:capacitor && cap run android"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.7",
    "@angular/ssr": "^21.2.6",
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.5",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/status-bar": "^7.0.6",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@capacitor/cli": "^7.6.5",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
